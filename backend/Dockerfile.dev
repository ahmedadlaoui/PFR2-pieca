# ============================================
# Development Dockerfile
# ============================================
FROM maven:3.9-eclipse-temurin-17

WORKDIR /app

# Install fswatch or entr to watch for file changes
RUN apt-get update && apt-get install -y entr wget

# Copy a small script to watch source files and trigger maven compile
COPY dev-watch.sh /usr/local/bin/dev-watch
RUN chmod +x /usr/local/bin/dev-watch

# The default command runs our watch script
CMD ["dev-watch"]
