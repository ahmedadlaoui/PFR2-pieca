# ============================================
# Development Dockerfile
# ============================================
FROM node:22-alpine

WORKDIR /app

# Install Angular CLI globally so 'ng serve' is available
RUN npm install -g @angular/cli@20.3.0

# The actual source code and node_modules will be mounted via docker-compose.
# We run npm install at startup (if needed) and then start the dev server.
# --host 0.0.0.0 ensures the server is accessible from outside the container
# --poll 2000 ensures hot-reloading works even if Docker file events are dropped
CMD npm install && ng serve --host 0.0.0.0 --poll 2000
