# ============================================
# Development Dockerfile
# ============================================
FROM node:20-bookworm-slim

WORKDIR /app

# Install Angular CLI globally so 'ng serve' is available
RUN npm install -g @angular/cli@20.3.0

# Improve file-watch stability on Docker Desktop bind mounts (Windows/macOS)
ENV CHOKIDAR_USEPOLLING=true

# The actual source code and node_modules are mounted via docker-compose.
# Reinstall dependencies if the mounted node_modules is missing Angular builders.
# --host 0.0.0.0 ensures the server is accessible from outside the container
# --poll 2000 ensures hot-reloading works even if Docker file events are dropped
CMD ["sh", "-lc", "if [ ! -f node_modules/@angular/build/package.json ]; then rm -rf node_modules; npm ci; fi; npm run start -- --host 0.0.0.0 --poll 2000"]
